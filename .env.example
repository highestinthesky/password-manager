# Copy to .env to enable sync (Layer 4). Without these, the app is local-only.
# URL + anon key: Supabase Dashboard → Project Settings → API.
# The anon key is designed to be public — Row Level Security does the guarding.
# VITE_SYNC_EMAIL is just an account identifier; the account password is
# derived from your master password automatically (never typed, never stored).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SYNC_EMAIL=you@example.com
