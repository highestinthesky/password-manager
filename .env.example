# Copy to .env to enable sync (Layer 4). Without these, the app is local-only.
# URL + anon key: Supabase Dashboard → Project Settings → API.
# The anon key is designed to be public — Row Level Security does the guarding.
# Sync email is entered in the app and stored per browser/device.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
